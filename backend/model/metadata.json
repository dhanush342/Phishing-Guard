    ],
    "Unit3_CSP_Knowledge": [
      "UrlConstraintSatisfaction: Variables, Domains, Constraints",
      "15 URL legitimacy constraints as arc-consistency checks",
      "PhishingKnowledgeBase: working memory + long-term rule store"
